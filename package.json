{
	"name": "telegram-stories-viewer-bot",
	"version": "1.0.0",
	"main": "./src/index.ts",
	"author": "k.khamidov <khamidoff09@gmail.com>",
	"license": "MIT",
	"scripts": {
		"dev": "nodemon",
		"start": "node dist/index.js",
		"build": "tsc && tsc-alias",
		"lint": "eslint src",
		"lint:fix": "eslint src --fix",
		"process:stop": "npx pm2 stop ecosystem.config.js && npx pm2 delete ecosystem.config.js",
		"process:start": "yarn build && npx pm2 start ecosystem.config.js",
		"deploy": "yarn process:stop && yarn process:start",
		"docker:login": "docker compose -f docker-compose.yml -f docker-compose.login.yml run --rm bot",
		"userbot-login": "node -r tsconfig-paths/register -r ts-node/register ./src/userbot-login.ts"
	},
	"dependencies": {
		"@supabase/supabase-js": "^2.105.4",
		"better-sqlite3": "^12.9.0",
		"dotenv": "^17.4.2",
		"effector": "^23.4.4",
		"input": "^1.0.1",
		"patronum": "^2.3.0",
		"telegraf": "^4.16.3",
		"telegram": "2.26.22"
	},
	"engines": {
		"node": ">=18"
	},
	"devDependencies": {
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "^22.19.3",
		"eslint": "^8.57.1",
		"eslint-import-resolver-node": "^0.3.9",
		"eslint-kit": "^11.39.0",
		"eslint-plugin-import": "^2.31.0",
		"nodemon": "^3.1.14",
		"prettier": "^3.8.3",
		"ts-node": "^10.9.2",
		"tsc-alias": "^1.8.17",
		"tsconfig-paths": "^4.2.0",
		"typescript": "^5.9.3"
	}
}
