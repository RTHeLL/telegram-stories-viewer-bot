DEV_BOT_TOKEN=
PROD_BOT_TOKEN=

USERBOT_API_ID=
USERBOT_API_HASH=
USERBOT_PHONE_NUMBER=

# Docker: первый вход userbot (код из Telegram) — docker-compose.login.yml запускает dist/userbot-login.js
# Альтернатива локально (без сборки образа при dev): yarn userbot-login
#   yarn docker:login
# или: docker compose -f docker-compose.yml -f docker-compose.login.yml run --rm bot

BOT_ADMIN_ID=

# Интервал фонового мониторинга подписок (миллисекунды). Минимум 60000. По умолчанию 3600000 (1 ч).
# MONITOR_INTERVAL_MS=3600000

# Хранение пользователей: sqlite | supabase
# Если не задано — supabase (как раньше). Для локального файла: DATA_STORAGE=sqlite
# DATA_STORAGE=sqlite
# Путь к файлу SQLite (от корня процесса), только при DATA_STORAGE=sqlite
SQLITE_DATABASE_PATH=data/users.db

# При DATA_STORAGE=supabase (или переменная не задана)
SUPABASE_PROJECT_URL=
SUPABASE_API_KEY=

NODE_ENV=
