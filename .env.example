DEV_BOT_TOKEN=
PROD_BOT_TOKEN=

USERBOT_API_ID=
USERBOT_API_HASH=
USERBOT_PHONE_NUMBER=

# Docker: первый вход userbot (код из Telegram) — интерактивно, том сессии общий с сервисом:
#   yarn docker:login
# или: docker compose -f docker-compose.yml -f docker-compose.login.yml run --rm bot
# Затем: docker compose up -d

BOT_ADMIN_ID=

# Хранение пользователей: sqlite | supabase
# Если не задано — supabase (как раньше). Для локального файла: DATA_STORAGE=sqlite
# DATA_STORAGE=sqlite
# Путь к файлу SQLite (от корня процесса), только при DATA_STORAGE=sqlite
SQLITE_DATABASE_PATH=data/users.db

# При DATA_STORAGE=supabase (или переменная не задана)
SUPABASE_PROJECT_URL=
SUPABASE_API_KEY=

NODE_ENV=
